{
    "manifest_version": 2,
    "background": {
        "page":"background.htm"
    },
    "browser_action": {
        "default_icon": "images/anesidora-debug-128.png",
        "browser_style": false,
        "default_popup": "cozy.htm"
    },
    "description": "Tabs? Where we're listening, we don't need tabs.",
    "icons": {
        "128": "images/anesidora-debug-128.png",
        "16": "images/anesidora-debug-16.png",
        "48": "images/anesidora-debug-48.png"
    },
    "name": "Anesidora",
    "omnibox": {
        "keyword": "radio"
    },
    "homepage_url": "http://github.com/pvrs12/anesidora",
    "options_page": "options.htm",
    "permissions": [
        "declarativeNetRequest",
        "http://*.pandora.com/*",
        "https://*.pandora.com/*",
        "http://*.p-cdn.com/*",
        "https://*.p-cdn.com/*",
        "http://*.p-cdn.us/*",
        "https://*.p-cdn.us/*"
    ],
    "declarative_net_request": {
        "rule_resources": [{
            "id": "ruleset",
            "enabled": true,
            "path": "declarativeNetRules.json"
        }]
    },
    "commands": {
        "skip_back": {
            "description": "Skip back"
        },
        "pause_play": {
            "description": "Play/Pause"
        },
        "skip_song": {
            "description": "Skip forward"
        },
        "_execute_browser_action": {
            "description": "Open player popup",
            "suggested_key": {
                "default": "Ctrl+Space"
            }
        }
    },
    "version": "3.0.0",
    "options_ui": {
        "page": "options.htm",
        "chrome_style": false
    }
}
